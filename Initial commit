        }

        // --- AUDIO ENGINE ---
        async function playGuide(key) {
            let text = "";
            switch(key) {
                case 'welcome': text = "欢迎来到协作纪元个人空间。我是你的导览助手。请浏览数据分析或开启创意实验室，见证人机共生的成果。"; break;
                case 'project1': text = "这是语义化数据库架构项目。Gemini 的推理引擎极大地优化了数据查询的路径权重。"; break;
                case 'project2': text = "这是自适应 UI 引擎。它利用视觉分析能力，让界面能够真正读懂用户的交互潜台词。"; break;
                case 'project3': text = "实时代码审计卫士，是我们在安全工程领域的突破，实现了零延迟的逻辑漏洞拦截。"; break;
                default: text = key;
            }

            try {
                const base64Audio = await callGeminiTTS(text, "Fenrir");
                if (base64Audio) {
                    const audioBlob = pcmToWav(base64Audio, 24000);
                    const audioUrl = URL.createObjectURL(audioBlob);
                    const player = document.getElementById('global-audio-player');
                    player.src = audioUrl;
                    player.play();
                }
            } catch (e) { console.error("TTS Error", e); }
        }

        // PCM to WAV converter for Gemini Audio
        function pcmToWav(base64, sampleRate) {
            const byteChars = atob(base64);
            const byteNums = new Array(byteChars.length);
            for (let i = 0; i < byteChars.length; i++) byteNums[i] = byteChars.charCodeAt(i);
            const buffer = new Uint8Array(byteNums).buffer;
            const view = new DataView(buffer);
            const wavBuffer = new ArrayBuffer(44 + buffer.byteLength);
            const wavView = new DataView(wavBuffer);
            const writeStr = (off, s) => { for(let i=0; i<s.length; i++) wavView.setUint8(off+i, s.charCodeAt(i)); };
            writeStr(0, 'RIFF');
            wavView.setUint32(4, 36 + buffer.byteLength, true);
            writeStr(8, 'WAVE');
            writeStr(12, 'fmt ');
            wavView.setUint32(16, 16, true);
            wavView.setUint16(20, 1, true); // PCM
            wavView.setUint16(22, 1, true); // Mono
            wavView.setUint32(24, sampleRate, true);
            wavView.setUint32(28, sampleRate * 2, true);
            wavView.setUint16(32, 2, true);
            wavView.setUint16(34, 16, true);
            writeStr(36, 'data');
            wavView.setUint32(40, buffer.byteLength, true);
            for(let i=0; i<buffer.byteLength; i++) wavView.setUint8(44 + i, view.getUint8(i));
            return new Blob([wavBuffer], { type: 'audio/wav' });
        }

        // --- CHARTS INITIALIZATION ---
        window.onload = function() {
            // Label Wrapping logic (Requirement: split labels > 16 chars)
            function wrapLabels(labels) {
                return labels.map(label => {
                    if (label.length > 16) {
                        const words = label.split(''); // Use character split for mixed languages
                        const result = [];
                        let currentLine = "";
                        words.forEach(char => {
                            if (currentLine.length > 14) {
                                result.push(currentLine);
                                currentLine = char;
                            } else {
                                currentLine += char;
                            }
                        });
                        result.push(currentLine);
                        return result;
                    }
                    return label;
                });
            }

            // Shared Tooltip Config (Requirement: callbacks.title)
            const commonTooltip = {
                plugins: {
                    tooltip: {
                        callbacks: {
                            title: function(tooltipItems) {
                                const item = tooltipItems[0];
                                let label = item.chart.data.labels[item.dataIndex];
                                return Array.isArray(label) ? label.join('') : label;
                            }
                        }
                    }
                }
            };

            // Capability Radar Chart
            const ctxRadar = document.getElementById('capabilityRadar').getContext('2d');
            new Chart(ctxRadar, {
                type: 'radar',
                data: {

                const response = await callGeminiText(prompt, "你是一个充满创意的顶级科技实验室负责人。");
                display.innerText = response;
                playGuide("✨ 新创意已就绪。");
            } catch (err) {
                display.innerText = "创意链路中断，请检查 API 密钥状态。";
            } finally {
                overlay.classList.add('hidden');
            }
        }

        async function auditProject() {
            const input = document.getElementById('audit-input').value.trim();
            if (!input) return;

            const resultBox = document.getElementById('audit-result');
            const btn = document.getElementById('audit-btn');
            const overlay = document.getElementById('ai-loading-overlay');

            btn.disabled = true;
            overlay.classList.remove('hidden');

            try {
                const prompt = `审计以下项目构想并给出 0-100 的协作契合度评分：\n\n"${input}"\n\n请指出协作的难点并给出优化建议。使用简洁的中文。`;
                const response = await callGeminiText(prompt, "你是一个严谨的高级系统架构师。");
                resultBox.classList.remove('hidden');
                resultBox.innerHTML = `
                    <div class="p-4 bg-slate-900/80 rounded-xl border border-white/10 mt-4">
                        <strong class="text-cyan-400 block mb-2">✨ 审计分析报告:</strong>
                        <p class="text-slate-300 leading-relaxed">${response.replace(/\n/g, '<br>')}</p>
                    </div>
                `;
            } catch (err) {
                resultBox.classList.remove('hidden');
                resultBox.innerHTML = `<p class="text-red-400 mt-4">审计服务暂不可用。</p>`;
            } finally {

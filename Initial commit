    <script>
        const apiKey = ""; // Staged for runtime
        const textModel = "gemini-2.5-flash-preview-09-2025";
        const ttsModel = "gemini-2.5-flash-preview-tts";

        // --- EXPONENTIAL BACKOFF FETCH ---
        async function fetchWithRetry(url, options, retries = 5, delay = 1000) {
            try {
                const response = await fetch(url, options);
                if (!response.ok) throw new Error(`HTTP Error ${response.status}`);
                return await response.json();
            } catch (err) {
                if (retries > 0) {
                    await new Promise(r => setTimeout(r, delay));
                    return fetchWithRetry(url, options, retries - 1, delay * 2);
                }
                throw err;
            }
        }

        // --- GEMINI API HELPERS ---
        async function callGeminiText(prompt, systemInstruction = "") {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/${textModel}:generateContent?key=${apiKey}`;
            const body = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: systemInstruction }] }
            };
            const result = await fetchWithRetry(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            return result.candidates?.[0]?.content?.parts?.[0]?.text;
        }

        async function callGeminiTTS(text, voice = "Kore") {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/${ttsModel}:generateContent?key=${apiKey}`;
            const body = {
                contents: [{ parts: [{ text: `Say naturally: ${text}` }] }],
                generationConfig: {
                    responseModalities: ["AUDIO"],
                    speechConfig: {
                        voiceConfig: { prebuiltVoiceConfig: { voiceName: voice } }
                    }
                }
            };
            const result = await fetchWithRetry(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            return result.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
        }

        // --- UI ACTIONS ---
        async function generateIdea() {
            const display = document.getElementById('inspiration-display');
            const overlay = document.getElementById('ai-loading-overlay');
            overlay.classList.remove('hidden');

            try {
